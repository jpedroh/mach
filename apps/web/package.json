{
  "name": "@mach/web",
  "type": "module",
  "scripts": {
    "serve": "react-router dev",
    "pack": "react-router build",
    "lint": "eslint app/",
    "react-router-generate-types": "react-router typegen",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@mach/shared-database": "workspace:*",
    "@mach/web-details": "workspace:*",
    "@mach/web-home": "workspace:*",
    "@mach/web-search": "workspace:*",
    "@mach/web-shared-ui": "workspace:*",
    "@react-router/cloudflare": "^7.14.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/fs-routes": "^7.14.1",
    "isbot": "^5",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@cloudflare/workers-types": "^4.20260414.1",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.81.1"
  },
  "nx": {
    "tags": [
      "type:application"
    ],
    "targets": {
      "pack": {
        "outputs": [
          "{projectRoot}/build"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "react-router-generate-types"
        ],
        "inputs": [
          "{projectRoot}/app"
        ],
        "outputs": [
          "{projectRoot}/.react-router/types"
        ]
      }
    }
  }
}
