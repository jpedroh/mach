{
  "extends": "@total-typescript/tsconfig/bundler/dom/library-monorepo",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "outDir": "./out-tsc/lib"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts"],
  "references": [
    {
      "path": "../web-shared-ui/tsconfig.lib.json"
    },
    {
      "path": "../shared-database/tsconfig.lib.json"
